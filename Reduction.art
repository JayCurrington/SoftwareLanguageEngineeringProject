//!try "a := 6; b := 9; while a != b do if (a > b) then a := a - b; else b := b - a;"


(*Rules and basic descriptions*)
//notes : C C# Db D D# Eb E F F# Gb G G# Ab A A# Bb B X <- rest
//chord-> change the type of chord | chord [str]; - Major, Minor, Major7, Minor7
//octave -> changes octave | octave [int];
//bpm -> changes bpm | bpm [int]
//instrument -> changes instument | instrument [str]; - piano, guitar, elecGuitar, drums, bass, trumpet, ocarina, violin (for setNotes only)
//channel -> changes the channel you are playing on - channels hold instument data and sequences | channel [int]; - 0 to 3

//setNotes -> sets a series of notes in current channel. Plays when start is called | setNotes [str],[str],[str]

//if | if ([expression]) then [sequence] OR if [expression] then [sequence] else [sequence]
//for | for ([expression]) do [sequence] then [sequence]
//while | while [expression] do [statement]
//switch | switch [str] : case ([str]) [statement] break; ...(as many cases as needed)... default [statement]

//function and run under construction and not working. need to implement hash map as in 6.13
//function [assign] [statement] - assign is function name and function does statement
//run [assign] - runs function

//play -> immediately plays a chord  play [str],[str];
//start -> runs all four channel's notes at once, one note per beat at current bpm | start;


